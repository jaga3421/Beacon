<?xml version="1.0" encoding="utf-8"?>
<!--
    Beacon launcher foreground — WiFi Meter icon
    Design: three concentric WiFi arcs + meter needle emanating from the pivot dot.
    The arcs span ±65° from vertical (130° total), centred at the pivot (54, 72).
    The needle points upper-right at 45° and terminates inside the outer arc.
    All paths use the app's electric-blue accent so the glyph reads on any background.

    Canvas: 108 × 108 dp  |  Safe zone: 18–90 dp (72 × 72 dp centred square)
    Pivot: (54, 72)  |  Outer r=40  Middle r=28  Inner r=16  Needle length ≈ 34 dp
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Outer WiFi arc — touches the safe-zone boundary ──────────────── -->
    <path
        android:pathData="M 18,55 A 40,40 0 0 1 90,55"
        android:fillColor="#00000000"
        android:strokeColor="#5B8CFF"
        android:strokeWidth="5.5"
        android:strokeLineCap="round" />

    <!-- ── Middle WiFi arc ───────────────────────────────────────────────── -->
    <path
        android:pathData="M 29,60 A 28,28 0 0 1 79,60"
        android:fillColor="#00000000"
        android:strokeColor="#5B8CFF"
        android:strokeWidth="5.5"
        android:strokeLineCap="round" />

    <!-- ── Inner WiFi arc ────────────────────────────────────────────────── -->
    <path
        android:pathData="M 40,65 A 16,16 0 0 1 68,65"
        android:fillColor="#00000000"
        android:strokeColor="#5B8CFF"
        android:strokeWidth="5.5"
        android:strokeLineCap="round" />

    <!-- ── Meter needle — 45° upper-right, sits inside outer arc ─────────── -->
    <path
        android:pathData="M 54,72 L 78,48"
        android:fillColor="#00000000"
        android:strokeColor="#5B8CFF"
        android:strokeWidth="5.5"
        android:strokeLineCap="round" />

    <!-- ── Pivot dot ─────────────────────────────────────────────────────── -->
    <path
        android:pathData="M 54,72 m -4.5,0 a 4.5,4.5 0 1,0 9,0 a 4.5,4.5 0 1,0 -9,0"
        android:fillColor="#5B8CFF" />

</vector>
